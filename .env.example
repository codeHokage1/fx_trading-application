# App
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_db_password
DB_NAME=fx_trading

# JWT
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email — Resend (https://resend.com)
# Note: use onboarding@resend.dev as MAIL_FROM for testing without a verified domain
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=onboarding@resend.dev

# FX Rates — exchangerate-api.com (https://www.exchangerate-api.com)
FX_API_KEY=your_fx_api_key_here
FX_BASE_URL=https://v6.exchangerate-api.com/v6
FX_CACHE_TTL_SECONDS=300

# Redis (optional — app falls back to in-memory cache if unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379

# Wallet
INITIAL_NGN_BALANCE=1000
